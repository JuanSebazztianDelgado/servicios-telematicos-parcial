

# Zona directa
zone "empresa.local" {

    type master;
    file "/etc/bind/db.empresa.local";
    allow-transfer { 192.168.50.2; };   # Solo el esclavo
    notify yes;

};

# Zona inversa
zone "50.168.192.in-addr.arpa" {

    type master;
    file "/etc/bind/db.192.168.50";
    allow-transfer { 192.168.50.2; };
    notify yes;

};

zone "sebastiandelgado.com" {
    type master;
    file "/etc/bind/db.sebastiandelgado.com";
};


